---
import Layout from '~/layouts/Layout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const title = `خطأ 404`;
---

<Layout metadata={{ title, robots: { index: false, follow: true } }}>
  <section class="flex items-center h-full p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">خطأ</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-3xl font-semibold md:text-3xl">عذراً، لم نتمكن من العثور على هذه الصفحة.</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">
          لا تقلق، يمكنك العثور على الكثير من المحتوى المفيد في صفحتنا الرئيسية.
        </p>
        <a rel="noopener noreferrer" href={getHomePermalink()} class="btn">العودة للصفحة الرئيسية</a>
      </div>
    </div>
  </section>
</Layout>
