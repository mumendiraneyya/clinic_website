---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import { getCanonical, getPermalink, cleanSlug } from '~/utils/permalinks';
import { buildProcedureFaq, buildProcedureFacts, resolveAlternatives } from '~/utils/procedure';
import type { MetaData } from '~/types';

export const prerender = true;

export const getStaticPaths = (async () => {
  const entries = await getCollection('procedure', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { procedure: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const SITE_URL = 'https://abuobaydatajjarrah.com';
const url = getCanonical(getPermalink(`/عمليات/${entry.id}`));

const metadata: MetaData = {
  title: d.title,
  description: d.excerpt,
  canonical: d.metadata?.canonical || String(url),
};

const faq = buildProcedureFaq(d);
const facts = buildProcedureFacts(d);

// Link alternatives to their procedure pages when those pages exist.
const allProcedures = await getCollection('procedure', ({ data }) => !data.draft);
const procedureSlugs = new Set(allProcedures.map((p) => p.id));
const alternatives = resolveAlternatives(d, (s) => procedureSlugs.has(s));

// Resolve the related blog post to its real title (match/link by cleaned slug,
// so the LIFT post — file `…-LIFT`, URL `…-lift` — links correctly).
let related: { href: string; title: string } | null = null;
if (d.relatedArticle) {
  const match = (await getCollection('post')).find((p) => cleanSlug(p.id) === d.relatedArticle);
  if (match) related = { href: `/${cleanSlug(match.id)}`, title: match.data.title };
}

// Schema: MedicalProcedure + FAQPage, @id-linked to the homepage Physician/Clinic.
const procedureSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalProcedure',
  '@id': `${String(url)}#procedure`,
  name: d.title,
  alternateName: d.nameEn,
  ...(d.bodyLocation ? { bodyLocation: d.bodyLocation } : {}),
  ...(d.procedureType ? { procedureType: { '@type': 'MedicalProcedureType', name: d.procedureType } } : {}),
  ...(d.candidate ? { indication: { '@type': 'MedicalIndication', name: d.candidate } } : {}),
  ...(d.contraindications ? { contraindication: { '@type': 'MedicalContraindication', name: d.contraindications } } : {}),
  performer: { '@id': `${SITE_URL}/#physician` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': String(url) },
  inLanguage: 'ar',
};

const faqSchema = faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'الرئيسية', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'ماذا نعالج', item: `${SITE_URL}/#features` },
    { '@type': 'ListItem', position: 3, name: d.title, item: String(url) },
  ],
};

const schemas = [procedureSchema, ...(faqSchema ? [faqSchema] : []), breadcrumbSchema];
---

<Layout metadata={metadata} schemas={schemas}>
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-8 sm:py-12">
    <header class="mb-6">
      <h1 class="text-3xl sm:text-4xl font-bold leading-tight">{d.title}</h1>
      {d.nameEn && <p class="mt-1 text-muted text-sm" dir="ltr">{d.nameEn}</p>}
      {d.condition && <p class="mt-3 text-lg text-muted">الحالة المُعالَجة: {d.condition}</p>}
    </header>

    {facts.length > 0 && (
      <div class="my-8 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-slate-800 p-5">
        <h2 class="text-base font-semibold mb-3">حقائق سريعة</h2>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
          {facts.map((f) => (
            <div class="flex justify-between gap-3 border-b border-dashed border-gray-200 dark:border-gray-700 py-1">
              <dt class="text-muted">{f.label}</dt>
              <dd class="font-medium text-start">{f.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    )}

    <div class="prose prose-lg dark:prose-invert max-w-none rtl:text-right">
      <Content />
    </div>

    {(alternatives.length || d.candidate || d.contraindications) && (
      <div class="mt-8 space-y-3 text-sm">
        {d.candidate && <p><strong>المريض المرشّح:</strong> {d.candidate}</p>}
        {alternatives.length > 0 && (
          <p>
            <strong>البدائل لنفس الحالة:</strong>{' '}
            {alternatives.map((a, i) => (
              <Fragment>
                {i > 0 ? '، ' : ''}
                {a.href ? <a class="text-primary underline" href={a.href}>{a.name}</a> : <span>{a.name}</span>}
              </Fragment>
            ))}
          </p>
        )}
        {d.contraindications && <p><strong>موانع الإجراء:</strong> {d.contraindications}</p>}
      </div>
    )}

    {faq.length > 0 && (
      <section class="mt-10">
        <h2 class="text-2xl font-bold mb-4">أسئلة شائعة</h2>
        <div class="space-y-4">
          {faq.map((f) => (
            <details class="rounded-lg border border-gray-200 dark:border-gray-700 p-4">
              <summary class="font-semibold cursor-pointer">{f.q}</summary>
              <p class="mt-2 text-muted">{f.a}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    {related && (
      <p class="mt-10 text-sm">
        اقرأ أيضًا: <a class="text-primary underline" href={related.href}>{related.title}</a>
      </p>
    )}
  </section>
</Layout>
