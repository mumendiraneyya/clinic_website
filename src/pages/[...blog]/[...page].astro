---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/blog/Headline.astro';
import BlogPostsByCategory from '~/components/widgets/BlogPostsByCategory.astro';
import Button from '~/components/ui/Button.astro';
// import PostTags from "~/components/blog/Tags.astro";

import { blogListRobots, getStaticPathsBlogList } from '~/utils/blog';
import { getHomePermalink } from '~/utils/permalinks';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

// const allCategories = await findCategories();
// const allTags = await findTags();

const metadata = {
  title: `المنشورات${currentPage > 1 ? ` — الصفحة ${currentPage}` : ''}`,
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 pt-12 sm:pt-16 lg:pt-20 mx-auto max-w-4xl">
    <Headline
      subtitle="كتابات وأحاديث الطبيب استشاري الجراحة د. مؤمن ديرانية (أبو عبيدة الجراح)"
    >
      المنشورات
    </Headline>
  </section>

  <BlogPostsByCategory />

  <section class="px-6 sm:px-6 pb-12 sm:pb-16 lg:pb-20 mx-auto max-w-4xl">
    <div class="flex flex-wrap gap-4">
      <Button variant="tertiary" class="px-3 md:px-3" href={getHomePermalink()}>
        <Icon name="tabler:home" class="w-5 h-5 me-1" /> الصفحة الرئيسية
      </Button>
    </div>
  </section>
</Layout>
