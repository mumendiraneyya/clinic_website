---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import merge from 'lodash.merge';
import type { ImageMetadata } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';

import { getCanonical, getPermalink } from '~/utils/permalinks';
import { getStaticPathsBlogPost, blogPostRobots } from '~/utils/blog';
import { findImage } from '~/utils/images';
import type { MetaData } from '~/types';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

export const getStaticPaths = (async () => {
  return await getStaticPathsBlogPost();
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post } = Astro.props as Props;

const url = getCanonical(getPermalink(post.permalink, 'post'));
const image = (await findImage(post.image)) as ImageMetadata | string | undefined;

const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: {
      index: blogPostRobots?.index,
      follow: blogPostRobots?.follow,
    },
    openGraph: {
      type: 'article',
      ...(image
        ? { images: [{ url: image, width: (image as ImageMetadata)?.width, height: (image as ImageMetadata)?.height }] }
        : {}),
    },
  },
  { ...(post?.metadata ? { ...post.metadata, canonical: post.metadata?.canonical || url } : {}) }
) as MetaData;

const SITE_URL = 'https://abuobaydatajjarrah.com';

// Extract YouTube video ID from URL
function getYouTubeId(url: string): string | null {
  const m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|shorts\/))([^&?/]+)/);
  return m ? m[1] : null;
}

const videoId = post.videoUrl ? getYouTubeId(post.videoUrl) : null;

// Reference homepage entities by @id so Google resolves all author/publisher
// signals across the corpus to the canonical Physician + MedicalBusiness nodes.
const physicianRef = {
  '@type': 'Physician',
  '@id': `${SITE_URL}/#physician`,
  name: post.author || 'د. مؤمن ديرانية',
  url: SITE_URL,
};
const clinicRef = {
  '@type': 'MedicalBusiness',
  '@id': `${SITE_URL}/#clinic`,
  name: 'عيادة د. مؤمن ديرانية',
  url: SITE_URL,
};

const publishedISO = post.publishDate ? new Date(post.publishDate).toISOString() : undefined;
const modifiedISO = post.updateDate ? new Date(post.updateDate).toISOString() : publishedISO;

const articleSchema = videoId
  ? {
      '@context': 'https://schema.org',
      '@type': 'VideoObject',
      name: post.title,
      description: post.excerpt || post.title,
      thumbnailUrl: `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`,
      uploadDate: publishedISO,
      contentUrl: `https://www.youtube.com/watch?v=${videoId}`,
      embedUrl: `https://www.youtube.com/embed/${videoId}`,
      inLanguage: 'ar',
      creator: physicianRef,
      publisher: clinicRef,
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post.title,
      description: post.excerpt || '',
      ...(image ? { image: typeof image === 'string' ? image : image.src } : {}),
      datePublished: publishedISO,
      dateModified: modifiedISO,
      author: physicianRef,
      publisher: clinicRef,
      mainEntityOfPage: { '@type': 'WebPage', '@id': String(url) },
      inLanguage: 'ar',
    };

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'الرئيسية', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'المدونة', item: `${SITE_URL}/blog` },
    ...(post.category ? [{ '@type': 'ListItem', position: 3, name: post.category.title, item: `${SITE_URL}/category/${post.category.slug}` }] : []),
    { '@type': 'ListItem', position: post.category ? 4 : 3, name: post.title, item: String(url) },
  ],
};

// Emit MedicalProcedure schema when this post's frontmatter declares one.
// performer links by @id to the homepage Physician node so Google merges
// "the surgeon who performs this procedure" with the FRCS-credentialed
// entity defined on the homepage.
const procedureSchema = post.procedure
  ? {
      '@context': 'https://schema.org',
      '@type': 'MedicalProcedure',
      '@id': `${String(url)}#procedure`,
      name: post.procedure.name,
      ...(post.procedure.alternateName ? { alternateName: post.procedure.alternateName } : {}),
      ...(post.procedure.bodyLocation ? { bodyLocation: post.procedure.bodyLocation } : {}),
      ...(post.procedure.procedureType
        ? { procedureType: { '@type': 'MedicalProcedureType', name: post.procedure.procedureType } }
        : {}),
      performer: { '@id': `${SITE_URL}/#physician` },
      mainEntityOfPage: { '@type': 'WebPage', '@id': String(url) },
      inLanguage: 'ar',
    }
  : null;

const schemas = [articleSchema, breadcrumbSchema, ...(procedureSchema ? [procedureSchema] : [])];

// Procedures that point back to this article (reverse of relatedArticle) —
// derived at build, so the link is declared once on the procedure side.
const linkedProcedures = (await getCollection('procedure', ({ data }) => !data.draft))
  .filter((proc) => proc.data.relatedArticle === post.slug)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout metadata={metadata} schemas={schemas}>
  <SinglePost post={{ ...post, image: image }} url={url}>
    {post.Content ? <post.Content /> : <Fragment set:html={post.content || ''} />}
  </SinglePost>
  <ToBlogLink />
  {linkedProcedures.length > 0 && (
    <section class="mx-auto max-w-3xl px-4 sm:px-6 pb-6">
      <h2 class="text-xl font-bold mb-3">عمليات ذات صلة</h2>
      <ul class="space-y-1 text-sm">
        {linkedProcedures.map((proc) => (
          <li>
            <a class="text-primary underline" href={`/عمليات/${proc.id}`}>{proc.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )}
  <RelatedPosts post={post} />
</Layout>
