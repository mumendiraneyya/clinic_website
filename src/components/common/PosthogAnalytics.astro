---
interface Props {
    id: string;
    api_host: string;
    defaults: string;
    profiles: 'always';
}

const { id, ...posthogConfig } = Astro.props;
---

<script is:inline define:vars={ { id, posthogConfig } }>
    // Skip PostHog on dev servers and staging deployments
    var _ph_host = window.location.hostname;
    if (_ph_host !== 'localhost' && !_ph_host.match(/^127\./) && !_ph_host.endsWith('.pages.dev')) {
      // eslint-disable-next-line @typescript-eslint/no-unused-expressions, no-var, prefer-rest-params
