---
import { GoogleAnalytics } from '@astrolib/analytics';
import PosthogAnalytics from '~/components/common/PosthogAnalytics.astro'
import MetaPixel from '~/components/common/MetaPixel.astro';
import { ANALYTICS } from 'astrowind:config';

const googleAnalytics = ANALYTICS?.vendors?.googleAnalytics;
const posthog = ANALYTICS?.vendors?.posthog;
const metaPixel = ANALYTICS?.vendors?.metaPixel;
---

{
  !googleAnalytics ? null : 
    <GoogleAnalytics 
      id={googleAnalytics.id} 
      partytown={googleAnalytics.partytown} 
    />
}

{
  !posthog ? null :
    <PosthogAnalytics
      id={posthog.id}
      api_host={posthog.api_host}
      defaults={posthog.defaults}
      profiles={posthog.profiles}
    />
}

{
  !metaPixel ? null :
    <MetaPixel id={metaPixel.id} />
}
